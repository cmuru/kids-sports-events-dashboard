{
  "name": "kids-sports-calendar-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:data && npm run build:site",
    "build:data": "tsx src/build/run.ts",
    "build:site": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ical.js": "^1.5.0",
    "js-yaml": "^4.1.0",
    "luxon": "^3.5.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
